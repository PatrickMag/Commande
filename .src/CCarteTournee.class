' Gambas class file

' CCarteTournee.class - Orchestrateur de l'affichage des tournées

Private depotManager As New CDepotManager
Private shapeManager As New CCarteShapeManager
Private clientGeocodeur As New CClientGeocodeur
Private trajetOptimiseur As New CTrajetOptimiseur
Private marqueurAfficheur As New CMarqueurAfficheur
Private trajetRouteur As New CTrajetRouteur
Private depotAfficheur As New CDepotAfficheur

Private distanceTotale As Float = 0
Private nomChauffeur As String = ""

' ✅ MODIFICATION : idcpc au lieu de numTournee
Public Function AfficherTournee(mapView As MapView, idcpc As Integer, db As Connection, Optional idClientActuel As Long = 0) As Variant[]
  Dim tousLesPoints As Collection
  Dim pointsOptimises As Collection
  Dim infos As New Variant[]
  
  Print "🚚 Chargement tournée - idcpc : " & idcpc
  
  If idClientActuel > 0 Then
    Print "👤 Client actuel : ID " & idClientActuel
  Endif
  
  depotManager.Initialiser()
  shapeManager.Initialiser(mapView)
  
  nomChauffeur = RecupererChauffeur(idcpc, db)
  
  tousLesPoints = clientGeocodeur.RecupererClients(idcpc, db)
  
  If tousLesPoints.Count = 0 Then
    Print "❌ Aucun client géocodé"
    infos.Add(nomChauffeur)
    infos.Add(0.0)
    Return infos
  Endif
  
  pointsOptimises = trajetOptimiseur.Optimiser(tousLesPoints, depotManager.ObtenirPoint())
  
  distanceTotale = CalculerDistanceTotale(pointsOptimises)
  
  marqueurAfficheur.AfficherTous(mapView, pointsOptimises, idClientActuel)
  trajetRouteur.Tracer(mapView, pointsOptimises)
  depotAfficheur.Afficher(mapView, depotManager.ObtenirPoint())
  
  CentrerCarte(mapView)
  
  Print "✅ Tournée affichée : " & tousLesPoints.Count & " clients"
  Print "📏 Distance totale : " & Format(distanceTotale, "0.0") & " km"
  Print "👤 Chauffeur : " & nomChauffeur
  
  infos.Add(nomChauffeur)
  infos.Add(distanceTotale)
  Return infos
End

Private Sub CentrerCarte(mapView As MapView)
  mapView.Map.Center = depotManager.ObtenirPoint()
  mapView.Map.Zoom = 10
End

' ✅ MODIFICATION : idcpc au lieu de numTournee
Private Function RecupererChauffeur(idcpc As Integer, db As Connection) As String
  Dim rs As Result
  Dim chauffeur As String = "Non défini"
  
  Print "🔍 DEBUG Chauffeur - idcpc : " & idcpc
  
  ' ✅ Basé sur ton schéma : commandeparcamion.idncomcam = idcpc
  Try rs = db.Exec("SELECT cpc.cnumchauf, c.nom, c.prenom, cam.nomducamion " &
                   "FROM commandeparcamion cpc " &
                   "LEFT JOIN chauffeur c ON cpc.cnumchauf = c.idchauffeur " &
                   "LEFT JOIN camion cam ON cpc.comnumcam = cam.idimat " &
                   "WHERE cpc.idncomcam = &1 " &
                   "LIMIT 1", idcpc)
  
  If Error Then
    Print "⚠️ Erreur SQL : " & Error.Text
    Return chauffeur
  Endif
  
  If rs.Available Then
    Print "  ✅ Chauffeur trouvé !"
    
    If Not IsNull(rs["prenom"]) Then
      If Not IsNull(rs["nom"]) Then
        If Trim(rs["prenom"]) <> "" And Trim(rs["nom"]) <> "" Then
          chauffeur = rs["prenom"] & " " & rs["nom"]
        Endif
      Endif
    Endif
    
    If chauffeur = "Non défini" Then
      If Not IsNull(rs["nom"]) Then
        If Trim(rs["nom"]) <> "" Then
          chauffeur = rs["nom"]
        Endif
      Endif
    Endif
    
    If chauffeur = "Non défini" Then
      If Not IsNull(rs["nomducamion"]) Then
        If Trim(rs["nomducamion"]) <> "" Then
          chauffeur = rs["nomducamion"]
        Endif
      Endif
    Endif
    
  Else
    Print "  ❌ Aucun chauffeur trouvé"
  Endif
  
  Return chauffeur
End

Private Function CalculerDistanceTotale(pointsOptimises As Collection) As Float
  Dim keys As String[]
  Dim i As Integer
  Dim total As Float = 0
  Dim dist As New CDistance
  
  keys = pointsOptimises.Keys
  
  If keys.Count < 2 Then Return 0
  
  For i = 0 To keys.Count - 2
    total += dist.Calculer(pointsOptimises[keys[i]], pointsOptimises[keys[i + 1]])
  Next
  
  Return total
End