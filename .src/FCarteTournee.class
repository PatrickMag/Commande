' Gambas class file

Private carte As CCarteTournee
Private idcpc As Integer
Private dateDelivraison As Date
Private numCamion As String
Private idClientActuel As Long = 0
Private dejaCharge As Boolean = False
Private zoomPrecedent As Integer = 8
Private obsMapView As Observer

' ✅ MODIFICATION : idcpc en premier paramètre
Public Sub _new(pIdcpc As Integer, pDateLivr As Date, pNumCamion As String)
  idcpc = pIdcpc
  dateDelivraison = pDateLivr
  numCamion = pNumCamion
End

Public Sub DefinirClientActuel(idClient As Long)
  idClientActuel = idClient
End

Public Sub Form_Open()
  
  If dejaCharge Then Return
  
  If Not IsNull(MapView1) Then
    MapView1.Map.AddTile("OSM", "https://a.tile.openstreetmap.org/{z}/{x}/{y}.png")
    MapView1.Map.Center = MapPoint(45.4167, 0.9167)
    MapView1.Map.Zoom = 8
    MapView1.Map.Draw()
    Me.Text = "Camion " & numCamion & " - " & Format(dateDelivraison, "dd/mm/yyyy")
    
    Dim obj As Object
    Try obj = MapView1.Children[0]
    If Not Error Then
      Try obj = obj.Children[0]
      If Not Error Then
        obsMapView = New Observer(obj) As "MapViewInternal"
      Endif
    Endif
  Endif
  
  dejaCharge = True
End

Public Sub ChargerCarte()
  Dim infos As Variant[]
  Dim chauffeur As String
  Dim distance As Float
  
  If IsNull(MapView1) Then Return
  
  Me.Text = "⏳ Chargement camion " & numCamion & "..."
  
  If Not IsNull(MapView1.Map!tournee) Then MapView1.Map!tournee.Clear()
  If Not IsNull(MapView1.Map!trajet) Then MapView1.Map!trajet.Clear()
  If Not IsNull(MapView1.Map!depot) Then MapView1.Map!depot.Clear()
  
  carte = New CCarteTournee
  ' ✅ CORRECTION : Passer idcpc
  infos = carte.AfficherTournee(MapView1, idcpc, Connect.ccon, idClientActuel)
  
  If infos.Count = 2 Then
    chauffeur = infos[0]
    distance = infos[1]
    
    LabelChauffeur.Text = "👤 Chauffeur : " & chauffeur
    LabelDistance.Text = "📏 Distance : " & Format(distance, "0.0") & " km"
  Else
    LabelChauffeur.Text = "👤 Chauffeur : Non défini"
    LabelDistance.Text = "📏 Distance : 0.0 km"
  Endif
  
  Me.Text = "Camion " & numCamion & " - " & Format(dateDelivraison, "dd/mm/yyyy")
  
  CCarteClient.RecupererMessage()
End

Public Sub Form_Close()
End

Public Sub MapViewInternal_MouseWheel()
  Stop Event
End

Public Sub MapView1_Zoom()
  If MapView1.Map.Zoom < 9 Then MapView1.Map.Zoom = 9
  If MapView1.Map.Zoom > 14 Then MapView1.Map.Zoom = 14
  zoomPrecedent = MapView1.Map.Zoom
  MapView1.Map.Update()
  MapView1.Refresh()
End
