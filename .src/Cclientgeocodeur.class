' Gambas class file

' CClientGeocodeur.class - Responsable du géocodage des clients

Private geo As New CGeocode

' ✅ MODIFICATION : idcpc au lieu de numTournee
Public Function RecupererClients(idcpc As Integer, db As Connection) As Collection
  Dim rs As Result
  Dim clients As New Collection
  Dim i As Integer
  
  rs = ExecuterRequeteClients(idcpc, db)
  
  If Not rs.Available Then
    Print "❌ Aucun client sur cette tournée"
    Return clients
  Endif
  
  Print "📦 " & rs.Count & " clients trouvés"
  
  rs.MoveFirst
  For i = 0 To rs.Max
    GeocoderEtAjouterClient(rs, clients, db)
    rs.MoveNext
  Next
  
  Return clients
End

' ✅ TA REQUÊTE SIMPLIFIÉE (basée sur ton schéma)
Private Function ExecuterRequeteClients(idcpc As Integer, db As Connection) As Result
  Print "🔍 DEBUG SQL - idcpc: " & idcpc
  
  Return db.Exec("SELECT DISTINCT c.idcom, c.nom, c.adresse, c.adresse1, c.cp, c.ville, " &
                 "c.noml, c.adressel, c.adressel1, c.cpl, c.villel, c.lat, c.lon " &
                 "FROM commande c " &
                 "INNER JOIN lignecomparcamion lcc ON c.idcom = lcc.idcomcl " &
                 "WHERE lcc.idcpc = &1 " &
                 "ORDER BY c.idcom", idcpc)
End

Private Sub GeocoderEtAjouterClient(rs As Result, clients As Collection, db As Connection)
  Dim point As MapPoint
  Dim nom, adresse, adresse1, ville, cp As String
  Dim nomL, adresseL, adresseL1, villeL, cpL As String
  Dim clientKey As String
  Dim idcom As Integer = rs["idcom"]
  Dim geocodagePrecis As Boolean = False
  
  nom = rs["nom"]
  adresse = rs["adresse"]
  adresse1 = rs["adresse1"]
  ville = rs["ville"]
  cp = rs["cp"]
  
  nomL = rs["noml"]
  
  If Not IsNull(nomL) Then
    If Trim(nomL) <> "" Then
      nom = nomL
      adresseL = rs["adressel"]
      adresseL1 = rs["adressel1"]
      adresse = CAdresseUtils.ConstruireAdresse(adresseL, adresseL1)
      ville = rs["villel"]
      cp = rs["cpl"]
    Else
      adresse = CAdresseUtils.ConstruireAdresse(adresse, adresse1)
    Endif
  Else
    adresse = CAdresseUtils.ConstruireAdresse(adresse, adresse1)
  Endif
  
  point = GeocoderAvecCache(idcom, nom, adresse, ville, cp, rs, db, geocodagePrecis)
  
  If Not IsNull(point) Then
    clientKey = "client_" & idcom & "_" & nom
    clients.Add(point, clientKey)
  Endif
End

Private Function GeocoderAvecCache(idcom As Integer, nom As String, adresse As String, ville As String, cp As String, rs As Result, db As Connection, ByRef geocodagePrecis As Boolean) As MapPoint
  Dim point As MapPoint
  Dim lat, lon As Float
  Dim resultat As Variant[]
  
  geocodagePrecis = True
  
  If Not IsNull(rs["lat"]) And Not IsNull(rs["lon"]) Then
    lat = rs["lat"]
    lon = rs["lon"]
    
    If lat <> 0 And lon <> 0 And Abs(lat) > 0.0001 And Abs(lon) > 0.0001 Then
      point = New MapPoint(lat, lon)
      Print "💾 " & nom & " (depuis cache)"
      Return point
    Else
      Print "⚠️ " & nom & " : coordonnées invalides en cache (0,0), re-géocodage..."
    Endif
  Endif
  
  resultat = GeocoderViaAPIAvecPrecision(adresse, ville, cp)
  
  If resultat.Count = 2 Then
    point = resultat[0]
    geocodagePrecis = resultat[1]
    
    If Not IsNull(point) Then
      If geocodagePrecis Then
        SauvegarderDansCache(idcom, point, db)
        Print "✅ " & nom & " (adresse précise)"
      Else
        Print "⚠️ " & nom & " (ville seule, imprécis)"
      Endif
      Wait 2
    Else
      Print "❌ " & nom & " (géocodage échoué)"
    Endif
  Endif
  
  Return point
End

Private Function GeocoderViaAPIAvecPrecision(adresse As String, ville As String, cp As String) As Variant[]
  Dim point As MapPoint
  Dim estPrecis As Boolean = False
  Dim resultat As New Variant[]
  
  point = geo.GetCoordinates(adresse & " " & ville, cp)
  
  If Not IsNull(point) Then
    estPrecis = True
  Else
    point = geo.GetCoordinates(ville, cp)
    estPrecis = False
  Endif
  
  resultat.Add(point)
  resultat.Add(estPrecis)
  
  Return resultat
End

Private Sub SauvegarderDansCache(idcom As Integer, point As MapPoint, db As Connection)
  Try db.Exec("UPDATE commande SET lat = &1, lon = &2 WHERE idcom = &3", point.Lat, point.Lon, idcom)
End